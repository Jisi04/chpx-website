# Copy this file to .env (in this same backend/ folder) and fill in real
# values. .env is gitignored — never commit it.

PORT=4000

# Only these origins may call the API — your live site plus local dev.
# Comma-separate multiple values, e.g.:
# ALLOWED_ORIGIN=https://chpx.ph,http://localhost:5173
ALLOWED_ORIGIN=https://chpx.ph,http://localhost:5173

# SMTP credentials for sending contact-form emails. This uses the generic
# SMTP protocol, not a vendor-specific SDK, so switching providers later is
# just changing these values — no code change needed. Any of these work:
# Gmail (with an app password), SendGrid, Mailgun, Resend, Postmark, or your
# hosting provider's own mail relay.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Where contact-form submissions get emailed to, and what address they're sent from.
CONTACT_TO_EMAIL=contact@chpx.ph
SMTP_FROM=contact@chpx.ph
