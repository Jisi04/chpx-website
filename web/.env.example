# Copy this file to .env (in this same web/ folder) and fill in the real value.
# .env is gitignored — it should never be committed.
#
# VITE_FORMSPREE_ENDPOINT
#   The Contact section's "Send a Message" form posts here.
#   Get this by creating a form at https://formspree.io — after creating one,
#   Formspree gives you a URL like https://formspree.io/f/xxxxxxxx. Use that
#   full URL as the value below.
#
# Note: this is a Vite app with no backend, so anything with a VITE_ prefix
# gets baked into the built JavaScript and is visible to anyone who views the
# deployed site's source — this is about keeping the value out of git history
# and easy to change per environment, not about hiding it from end users.
#
# For the live Netlify deploy, also set this same variable in:
# Netlify dashboard → Site settings → Environment variables
# (the build won't have this value otherwise, since .env isn't committed).

VITE_FORMSPREE_ENDPOINT=https://formspree.io/f/YOUR_FORM_ID
